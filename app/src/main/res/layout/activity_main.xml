<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:text="🏎️ TILT RECEIVER"
        android:textSize="22sp" android:textStyle="bold"
        android:gravity="center" android:layout_marginBottom="16dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btnAccessibility"
        android:text="1. Enable Accessibility"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/btnStart"
        android:text="2. Start UDP"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>
    <Button android:id="@+id/btnStop"
        android:text="Stop"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvStatus"
        android:text="Ready..." android:textSize="16sp"
        android:textColor="#FF6600" android:gravity="center"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvData"
        android:text="Waiting..." android:textSize="13sp"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <!-- LEFT Point -->
    <TextView android:text="🕹️ Steering LEFT Point"
        android:textSize="15sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Steering wheel ke LEFT side pe ungli rakho"
        android:textSize="11sp" android:textColor="#888"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <EditText android:id="@+id/etLeftX" android:hint="Left X"
            android:inputType="numberDecimal"
            android:layout_weight="1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/etLeftY" android:hint="Left Y"
            android:inputType="numberDecimal"
            android:layout_weight="1" android:layout_width="0dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- RIGHT Point -->
    <TextView android:text="🕹️ Steering RIGHT Point"
        android:textSize="15sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Steering wheel ke RIGHT side pe ungli rakho"
        android:textSize="11sp" android:textColor="#888"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <EditText android:id="@+id/etRightX" android:hint="Right X"
            android:inputType="numberDecimal"
            android:layout_weight="1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/etRightY" android:hint="Right Y"
            android:inputType="numberDecimal"
            android:layout_weight="1" android:layout_width="0dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ACCEL -->
    <TextView android:text="🔥 Accelerator Button"
        android:textSize="15sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Gas button pe ungli rakho"
        android:textSize="11sp" android:textColor="#888"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <EditText android:id="@+id/etAccelX" android:hint="Accel X"
            android:inputType="numberDecimal"
            android:layout_weight="1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/etAccelY" android:hint="Accel Y"
            android:inputType="numberDecimal"
            android:layout_weight="1" android:layout_width="0dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <Button android:id="@+id/btnSaveCoords"
        android:text="💾 Save Coordinates"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

</LinearLayout>
</ScrollView>
