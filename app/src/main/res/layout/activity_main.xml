<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <TextView android:id="@+id/tvStatus" android:text="Accessibility: ❌ OFF"
            android:textColor="#FF6600" android:textSize="13sp"
            android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvPackets" android:text="Packets: 0"
            android:textColor="#666666" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <TextView android:id="@+id/tvTilt" android:text="Tilt: 0.00"
        android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <com.tiltsteering.receiver.SteeringWheelView
        android:id="@+id/wheelView"
        android:layout_width="240dp" android:layout_height="240dp"
        android:layout_marginBottom="20dp"/>

    <Button android:id="@+id/btnGas"
        android:text="⚡ GAS" android:textSize="24sp" android:textStyle="bold"
        android:textColor="#FFFFFF" android:backgroundTint="#44AA44"
        android:layout_width="180dp" android:layout_height="90dp"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnAccessibility"
        android:text="Enable Accessibility"
        android:textColor="#FFFFFF" android:backgroundTint="#333355"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

</LinearLayout>
